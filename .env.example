# Extraction (required for real conversions; demo mode works without it)
ANTHROPIC_API_KEY=

# Persistence (optional in dev — app falls back to in-memory jobs)
# When set, jobs, statements, usage and subscriptions persist in Postgres.
DATABASE_URL=            # Supabase Postgres, EU region (service role / direct connection)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Auth (better-auth). Requires DATABASE_URL to activate. With no secret the app
# stays in local mode: no sign-in wall, owner is always 'local'.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Billing (Stripe). Requires auth (secret + DATABASE_URL) to activate.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe price ids (create these in your Stripe catalogue; used by /pricing and checkout)
STRIPE_PRICE_SOLO=            # Solo monthly ($24/mo)
STRIPE_PRICE_SOLO_ANNUAL=     # Solo annual ($19/mo billed yearly)
STRIPE_PRICE_PRO=             # Pro monthly ($59/mo)
STRIPE_PRICE_PRO_ANNUAL=      # Pro annual ($49/mo billed yearly)
STRIPE_PRICE_PRACTICE=        # Practice monthly ($149/mo)
STRIPE_PRICE_PAYG=            # Pay-as-you-go: $9 per 100 pages (one-time)

# Auto-purge cron protection (optional). When set, /api/cron/purge requires it.
CRON_SECRET=

# Password-reset email delivery (optional — logs the link to console without it)
RESEND_API_KEY=
RESEND_FROM=Parseledger <no-reply@parseledger.co>
